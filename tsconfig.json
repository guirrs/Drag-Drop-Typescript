{
  "compilerOptions": {
    /* Basic Options */
    "target": "es2020", // Atualizado de es6 para suportar recursos mais novos
    "module": "es2015", 
    "lib": [
      "dom",
      "es2020", 
      "dom.iterable",
      "scripthost",
      "esnext.disposable" // Necessário para resolver os erros de 'Symbol.dispose'
    ],
    "sourceMap": true,
    "outDir": "./dist",
    // "rootDir": "./src",
    "removeComments": true,
    "noEmitOnError": true,
    "skipLibCheck": true, // <--- A CHAVE PARA LIMPAR OS 69 ERROS

    /* Strict Type-Checking Options */
    "strict": true,

    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    /* Module Resolution Options */
    "moduleResolution": "node", // Importante para o Webpack encontrar pacotes
    "esModuleInterop": true,

    /* Experimental Options */
    "experimentalDecorators": true
  },
  "exclude": [
    "node_modules"
  ]
}